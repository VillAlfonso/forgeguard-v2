# ╔══════════════════════════════════════════════════════════════╗
# ║           ForgeGuard SaaS - Configuration File              ║
# ║                                                              ║
# ║  Copy this file to .env and fill in YOUR values.             ║
# ║  Lines starting with # are comments.                         ║
# ║  Items marked [REQUIRED] must be set before running.         ║
# ║  Items marked [OPTIONAL] have working defaults.              ║
# ╚══════════════════════════════════════════════════════════════╝

# ============================================
# [REQUIRED] SECRET KEY
# ============================================
# Generate a random string for JWT signing. Example:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-generate-a-random-64-char-string

# ============================================
# [OPTIONAL] DATABASE
# ============================================
# Default: SQLite (no setup needed, file created automatically)
# For production, switch to PostgreSQL:
#   DATABASE_URL=postgresql://user:password@localhost:5432/forgeguard
DATABASE_URL=sqlite:///./forgeguard.db

# ============================================
# [OPTIONAL] LLM Configuration
# ============================================
# Choose ONE: local Ollama (free) or Groq Cloud (fast)

# Set to "true" for Groq Cloud, "false" for local Ollama
USE_CLOUD_LLM=false

# --- Groq Cloud (if USE_CLOUD_LLM=true) ---
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Local Ollama (if USE_CLOUD_LLM=false) ---
# Install: https://ollama.com/download  then pull a multimodal model so the
# explainer can see the image, e.g.:  ollama pull llama3.2-vision:11b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b

# ============================================
# [OPTIONAL] YOLO Configuration
# ============================================
YOLO_WEIGHTS_PATH=./weights/best.pt
CONFIDENCE_THRESHOLD=0.25

# ============================================
# [OPTIONAL] ROBOFLOW Hosted Inference
# ============================================
# When set, the digital_cut_paste category uses a Roboflow-hosted model
# instead of a local YOLO checkpoint. Other categories continue to use
# local weights until they are migrated.
#
# Get your private API key from: https://app.roboflow.com/<workspace>/settings/api
# The model id is "<project>/<version>" — visible in the Deploy tab snippet.
ROBOFLOW_API_KEY=
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_CUT_PASTE_MODEL=find-cut-and-paste/1

# ============================================
# [OPTIONAL] STRIPE PAYMENTS
# ============================================
# Leave blank to disable payments (app works without them).
# Sign up: https://dashboard.stripe.com
# Use TEST keys during development (start with sk_test_ / pk_test_)

# Secret key (backend) - from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=

# Publishable key (frontend) - from same page
STRIPE_PUBLISHABLE_KEY=

# Webhook secret - from Stripe Dashboard > Developers > Webhooks
# Create a webhook endpoint pointing to: https://your-domain.com/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Price IDs - Create products in Stripe Dashboard > Products
# Each price ID looks like: price_1ABC123...
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=

# ============================================
# [OPTIONAL] PLAN LIMITS
# ============================================
FREE_SCANS_PER_MONTH=10
BASIC_SCANS_PER_MONTH=100
PRO_SCANS_PER_MONTH=1000

# ============================================
# [OPTIONAL] JWT TOKEN EXPIRY
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# [OPTIONAL] URLS
# ============================================
# Change these when deploying to production.
# IMPORTANT: API_URL must be reachable from the user's device — the email
# verification link points at {API_URL}/api/auth/verify-email. On a LAN setup
# use your PC's IP (e.g. http://192.168.0.169:8000); behind Cloudflare Tunnel
# use the tunnel URL. FRONTEND_URL is where users land after confirming.
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000

# ============================================
# [OPTIONAL] EMAIL — required for sign-up email verification
# ============================================
# If left blank, the app still works but the verification link is printed to the
# backend console instead of emailed (useful for local testing).
#
# Gmail setup: enable 2-Step Verification on the Google account, then create an
# "App Password" (Google Account > Security > App passwords) and use that 16-char
# value as SMTP_PASSWORD (NOT your normal Gmail password).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   FROM_EMAIL=youraddress@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@forgeguard.app
